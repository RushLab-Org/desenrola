# Sacada IA — variáveis de ambiente
# Fonte da verdade: CLAUDE.md (seção "Variáveis previstas")
# Valores reais ficam no Doppler (projeto sacada-ia, environments dev + prod)
# NUNCA commitar valores reais neste arquivo

# ── Supabase ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Gemini ────────────────────────────────────────────────────────────────
GEMINI_API_KEY=

# ── Perfect Pay ───────────────────────────────────────────────────────────
# Webhook secret (painel Perfect Pay > Integrações > Webhook)
PERFECTPAY_WEBHOOK_SECRET=
# URL do checkout do produto (painel Perfect Pay > Produtos > Link de Pagamento)
# Sem essa variável o botão de compra fica desabilitado (aria-disabled)
NEXT_PUBLIC_PERFECTPAY_URL=

# ── App ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=

# ── Suporte ───────────────────────────────────────────────────────────────
# Exibido no footer da landing e na página de sucesso
NEXT_PUBLIC_SUPPORT_EMAIL=
